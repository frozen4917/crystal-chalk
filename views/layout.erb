<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

  <title><%= @page_title ? "#{@page_title} - #{@site_title}" : @site_title %></title>

  <% if @description && !@description.empty? %>
    <meta name="description" content="<%= @description %>">
  <% end %>

  <!-- Open Graph -->
  <meta property="og:type"        content="<%= @page_type || 'website' %>">
  <meta property="og:title"       content="<%= @page_title ? "#{@page_title} - #{@site_title}" : @site_title %>">
  <meta property="og:description" content="<%= @description %>">
  <%# og:url should be the full absolute URL. site_url is empty in dev so this degrades gracefully %>
  <meta property="og:url"         content="<%= @site_url + request.path %>">

  <%
    # Use the post's own image if present, otherwise fall back to the global og_image.
    # A post-specific image gets twitter:card summary_large_image; the fallback gets summary.
    og_img = (@image && !@image.empty?) ? @image : (@og_image && !@og_image.empty? ? @og_image : nil)
  %>

  <% if og_img %>
    <meta property="og:image"       content="<%= og_img %>">
    <meta name="twitter:card"       content="<%= (@image && !@image.empty?) ? 'summary_large_image' : 'summary' %>">
    <meta name="twitter:image"      content="<%= og_img %>">
  <% else %>
    <meta name="twitter:card" content="summary">
  <% end %>

  <meta name="twitter:title"       content="<%= @page_title || @site_title %>">
  <meta name="twitter:description" content="<%= @description %>">

  <% if @theme["favicon"] && !@theme["favicon"].empty? %>
    <link rel="icon" href="<%= @theme["favicon"] %>">
  <% end %>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/assets/main.css">

  <%# Theme colors are injected as CSS variables so all stylesheets can reference them %>
  <style>
    :root {
      --bg:       #<%= @theme["background_color"] %>;
      --text:     #<%= @theme["text_color"] %>;
      --accent:   #<%= @theme["accent_color"] %>;
      --gradient: #<%= @theme["gradient_color"] %>;
    }
  </style>
</head>

<body>
  <!-- Gradient strip at the top. Subtle, decorative. -->
  <% if @theme["enable_gradient"] %>
    <div class="gradient-crown"></div>
  <% end %>

  <div class="page-wrap">
    <header>
      <a href="/" class="site-title"><%= @site_title %></a>
      <% if @show_back %>
        <a href="/" class="back-link">← All posts</a>
      <% end %>
    </header>

    <main>
      <%= yield %>
    </main>

    <footer>
      <p><a href="https://github.com/frozen4917/crystal-chalk" target="_blank">powered by <span class="crystal-icon"></span> <strong>crystal chalk</strong></a></p>
    </footer>
  </div>
</body>

</html>