<p class="index-heading">All Posts</p>

<% if @posts.empty? %>
  <p class="empty-state">No posts yet. Drop a .md file in the pages/ directory.</p>
<% else %>
  <div class="post-grid">
    <% @posts.each do |post| %>
      <a href="/<%= post[:slug] %>" class="post-card">
        <div class="post-card-top">
          <span class="post-card-title"><%= post[:title] %></span>
          <% if post[:date] %>
            <span class="date-chip"><%= post[:date].strftime("%b %d, %Y") %></span>
          <% end %>
        </div>
        <% if !post[:description].empty? %>
          <p class="post-card-desc"><%= post[:description] %></p>
        <% end %>
      </a>
    <% end %>
  </div>
<% end %>